API_URL="http://api:80/chatbot"
POPULATE_CHROMA=1
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
PERSIST_DIRECTORY=/chroma/my_database
COLLECTION_NAME=pdf_vectors
DATASET_DIRECTORY=dataset
DATASET_MD_DIRECTORY=dataset_md
OPENAI_API_KEY=""

# Feature flags (off by default for the demo build)
ENABLE_WHATSAPP=0
ENABLE_AUTH=0

# Embedding provider — controls both the writer (populate_chroma) and the
# reader (api). Switching providers changes vector dims, so use a fresh
# COLLECTION_NAME (and wipe the chroma volume) when changing this.
#   chroma_default : Chroma's built-in MiniLM (384 dims, free, local)
#   openai         : OpenAIEmbeddings (1536 dims for text-embedding-3-small,
#                    requires OPENAI_API_KEY, costs per ingest)
EMBEDDING_PROVIDER=chroma_default
# EMBEDDING_MODEL=text-embedding-3-small
